# Telegram Bot Token dari @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Private key wallet kamu (dengan 0x di depan)
WALLET_PRIVATE_KEY=0xyour_private_key_here

# RPC URL untuk Base mainnet
BASE_RPC_URL=https://mainnet.base.org

# Mode auto-deploy (true/false)
AUTO_DEPLOY_ENABLED=false

# Jumlah ETH per round untuk auto-deploy (dalam ETH)
AUTO_DEPLOY_AMOUNT=0.0001

# Jumlah blocks per round untuk auto-deploy (1-25)
AUTO_DEPLOY_BLOCKS=5

# Minimum ETH balance sebelum stop auto-deploy
MIN_BALANCE_THRESHOLD=0.001

# Port untuk Railway (jangan diubah)
PORT=3000
